# Copy to .env for local development.
# In production these are set as Cloudflare Pages build-time env vars instead.

# Backend (Hono/Cloudflare Worker) base URL. API calls hit ${REACT_APP_API_URL}/api/...
# local:      http://127.0.0.1:8787   (wrangler dev, in ../hono-konfigurator-be)
# production: https://konfigurator-be.m1ck33kc1m.workers.dev
REACT_APP_API_URL=http://127.0.0.1:8787

# development | production
REACT_APP_NODE_ENV=development
