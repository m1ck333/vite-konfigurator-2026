# Copy to .env for local development.
# On DigitalOcean App Platform these are set as build-time env vars instead.

# Laravel backend base URL. API calls hit ${REACT_APP_API_URL}/api/...
# local:      http://127.0.0.1:8080
# production: https://konfigurator-api.online
REACT_APP_API_URL=http://127.0.0.1:8080

# development | production
REACT_APP_NODE_ENV=development
